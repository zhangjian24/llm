# 后端服务环境变量配置示例
# 复制此文件为 .env.local 并填入实际配置值

# ==================== 应用配置 ====================
APP_NAME=RAG Document QA System
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接（如使用 SQLite 可注释）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_qa_db

# SQLite 数据库路径（开发环境可选）
# DATABASE_URL=sqlite+aiosqlite:///./rag_qa.db

# ==================== Pinecone 向量数据库 ====================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_HOST=your-pinecone-host
PINECONE_INDEX_NAME=rag-documents-index

# ==================== 阿里云百炼 API 配置 ====================
# 用于调用 qwen-max、text-embedding-v4、rerank-v3 等模型
DASHSCOPE_API_KEY=your-dashscope-api-key

# OpenAI 兼容接口配置（如果使用其他 LLM 服务）
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 模型配置 ====================
# LLM 模型名称
LLM_MODEL=qwen-max

# Embedding 模型名称
EMBEDDING_MODEL=text-embedding-v4

# Rerank 模型名称
RERANK_MODEL=rerank-v3

# ==================== 服务配置 ====================
# FastAPI服务监听地址
HOST=0.0.0.0
PORT=8000

# CORS 允许的前端地址
FRONTEND_URL=http://localhost:5173

# ==================== 文件上传配置 ====================
# 最大文件大小（字节），默认 50MB
MAX_FILE_SIZE=52428800

# 文件存储根目录
UPLOAD_DIR=./uploads

# 允许的 MIME 类型
ALLOWED_MIME_TYPES=application/pdf,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ==================== RAG 配置 ====================
# 文本分块大小
CHUNK_SIZE=800

# 分块重叠量
CHUNK_OVERLAP=100

# 检索返回的最大文档数
MAX_RETRIEVAL_DOCS=10

# 重排序后返回的文档数
RERANK_TOP_K=5

# ==================== 日志配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志格式 (json, console)
LOG_FORMAT=json
