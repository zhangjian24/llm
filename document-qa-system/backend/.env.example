# OpenAI兼容接口配置
OPENAI_BASE_URL=your_openai_compatible_gateway_url
OPENAI_API_KEY=your_api_key_here

# Pinecone配置
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=document_qa_index
PINECONE_ENVIRONMENT=us-east-1-aws  # 如果使用serverless可为空

# 应用配置
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# 服务器配置
HOST=localhost
PORT=8000

# RAG配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=20
TOP_N_RERANK=5