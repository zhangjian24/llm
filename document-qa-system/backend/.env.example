# Pinecone Configuration (v5.3.0)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=document-qa-index

# Alibaba Cloud Qwen Configuration
QWEN_API_KEY=your_alibaba_cloud_api_key_here
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=rerank-v3
QWEN_LLM_MODEL=qwen-max

# Ollama Configuration (Legacy - will be deprecated)
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
EMBEDDING_MODEL=bge-m3
LLM_MODEL=gpt-oss:20b

# 或使用本地 Ollama 服务
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Upload Settings
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.pdf,.txt,.docx,.doc,.html,.htm
UPLOAD_FOLDER=./uploads

# Vector Store Settings
VECTOR_DIMENSION=768
TOP_K_RESULTS=5
SCORE_THRESHOLD=0.7

# Reranking Settings
RERANK_TOP_K=10
RERANK_SCORE_THRESHOLD=0.8

# Model Settings
MAX_TOKENS=2048
TEMPERATURE=0.7